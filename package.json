{
  "name": "k8tar-fieldday",
  "version": "2.0.0",
  "description": "Field Day Logger - ARRL Field Day Logging Application",
  "private": true,
  "type": "module",
  "main": "electron-main.js",
  "author": {
    "name": "K8TAR",
    "email": "support@k8tar.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test": "npm run test:unit && npm run test:ui",
    "test:unit": "vue-cli-service test:unit",
    "test:ui": "node test-scripts/test-release-validation.cjs",
    "test:watch": "vue-cli-service test:unit --watch",
    "test:pipeline": "bash test-scripts/test-pipeline.sh",
    "test:pipeline:windows": "test-scripts/test-pipeline.bat",
    "lint": "vue-cli-service lint",
    "lint:fix": "vue-cli-service lint --fix",
    "electron": "electron .",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "start": "npm run build && electron .",
    "start:dev": "npm run electron:dev"
  },
  "dependencies": {
    "marked": "^16.0.0",
    "node-fetch": "^3.3.2",
    "vue": "^3.2.13",
    "vue-router": "^4.0.3",
    "vuex": "^4.0.0"
  },
  "devDependencies": {
    "@types/chai": "^4.2.15",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^8.2.3",
    "@types/node": "^24.0.12",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "@vitejs/plugin-basic-ssl": "^2.1.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/cli-plugin-eslint": "~5.0.0",
    "@vue/cli-plugin-router": "~5.0.0",
    "@vue/cli-plugin-typescript": "~5.0.0",
    "@vue/cli-plugin-unit-mocha": "~5.0.0",
    "@vue/cli-plugin-vuex": "~5.0.0",
    "@vue/cli-service": "~5.0.0",
    "@vue/compiler-sfc": "^3.0.0-beta.1",
    "@vue/eslint-config-typescript": "^9.1.0",
    "@vue/test-utils": "^2.0.0-alpha.1",
    "chai": "^4.2.0",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "puppeteer": "^24.12.1",
    "sass": "^1.32.7",
    "sass-loader": "^12.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.3"
  },
  "build": {
    "appId": "com.k8tar.fieldday",
    "productName": "Field Day Logger",
    "directories": {
      "output": "dist-installers"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "src/preload.js",
      "package.json",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "menuCategory": "Amateur Radio",
      "license": "LICENSE",
      "installerHeaderIcon": "public/favicon.ico",
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
