{
  "name": "k8tar-fieldday",
  "version": "1.0.0-alpha",
  "description": "Field Day Logger - ARRL Field Day Logging Application",
  "main": "electron-main.js",
  "homepage": "./",
  "private": true,
  "type": "module",
  "author": {
    "name": "K8TAR",
    "email": "support@k8tar.com"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "test:unit": "vitest run --globals tests/unit",
    "lint": "eslint --max-warnings=0 --ext .ts,.vue ./src",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on https://localhost:8080 && electron .\"",
    "electron:pack": "electron-builder",
    "electron:dist": "npm run build && electron-builder",
    "dist": "npm run build && npm run electron:pack",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "build:installer": "node build-pipeline.js",
    "release": "npm run build && npm run electron:pack && npm run build:installer"
  },
  "build": {
    "appId": "com.k8tar.fieldday",
    "productName": "Field Day Logger",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "src/preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "zip",
          "arch": ["x64", "ia32"]
        }
      ],
      "icon": "public/favicon.ico",
      "publisherName": "K8TAR",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico",
      "installerHeaderIcon": "public/favicon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": "Amateur Radio"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "public/favicon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "icon": "public/favicon.png",
      "category": "Utility"
    },
    "extraMetadata": {
      "main": "electron-main.js"
    }
  },
  "dependencies": {
    "electron": "^41.7.1",
    "marked": "^16.0.0",
    "node-fetch": "^3.3.2",
    "postcss": "^8.5.15",
    "vue": "^3.5.38",
    "vue-router": "^4.0.3",
    "vuex": "^4.0.0"
  },
  "devDependencies": {
    "@types/chai": "^4.2.15",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^5.4.0",
    "@typescript-eslint/parser": "^5.4.0",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.38",
    "@vue/eslint-config-typescript": "^9.1.0",
    "@vue/test-utils": "^2.0.0-alpha.1",
    "chai": "^4.2.0",
    "concurrently": "^9.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^7.32.0",
    "eslint-plugin-vue": "^8.0.3",
    "esbuild": "^0.28.1",
    "puppeteer": "^24.43.1",
    "sass": "^1.101.0",
    "sass-loader": "^12.0.0",
    "vitest": "^4.1.8",
    "typescript": "^5.8.3",
    "vite": "^8.0.16",
    "wait-on": "^8.0.0"
  }
}
